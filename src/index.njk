---
layout: index.njk
title: Local AI
description: A community for running AI offline and completely privately on your own computer. No internet required, no subscriptions, no data sharing.
permalink: "/"
fullWidth: true
---

<!-- ── HERO ─────────────────────────────────── -->
<section class="cosmos-hero-pcb">
<canvas class="pcb-canvas" id="enclosureCanvas"></canvas>
<div class="hero-content">
<h1 class="hero-main">{{ home.hero.title }}</h1>
<p class="hero-minor">{{ home.hero.lead }}</p>
</div>
<div class="pcb-ctas">
{% for cta in home.hero.ctas %}
<a href="{{ cta.href }}" class="pcb-cta pcb-cta--{{ cta.accent }}"{% if cta.external %} target="_blank" rel="noopener"{% endif %}>
<span class="pcb-cta__label"><i class="bi {{ cta.icon }} me-1"></i>{{ cta.label }}</span>
</a>
{% endfor %}
</div>
<div class="hero-scroll-hint" id="heroScrollHint">
  <span class="hero-scroll-label">SCROLL</span>
  <div class="hero-scroll-bounce">
    <div class="hero-scroll-spin" id="heroScrollSpin">
      <i class="bi bi-chevron-down"></i>
    </div>
  </div>
</div>
</section>

<!-- ── WHAT IS LOCAL AI ──────────────────────── -->
<section class="cosmos-section cosmos-section--raised">
  <div class="container">
    <h2 class="cosmos-section__title">{{ home.whatIsLocalAI.title }}</h2>
    <p class="cosmos-section__lead">{{ home.whatIsLocalAI.lead }}</p>
    <a href="{{ home.whatIsLocalAI.button.href }}" class="btn btn-outline-primary mt-2">{{ home.whatIsLocalAI.button.label }} <i class="bi bi-arrow-right ms-1"></i></a>
  </div>
</section>

<!-- ── UPCOMING EVENTS ─────────────────────── -->
<section class="cosmos-section cosmos-section--dots-events">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
      <div>
        <h2 class="cosmos-section__title cosmos-section__title--events mb-0"><i class="bi bi-calendar-event me-2"></i>{{ home.events.title }}</h2>
      </div>
      <a href="{{ home.events.viewAllHref }}" class="cosmos-view-all cosmos-view-all--events d-none d-md-inline-flex"{% if home.events.viewAllExternal %} target="_blank" rel="noopener"{% endif %}>
        {{ home.events.viewAllLabel }} <i class="bi bi-arrow-right"></i>
      </a>
    </div>
    {% if collections.upcomingEvents | length %}
      {% set type = "upcoming" %}
      {% include "partials/eventsList.njk" %}
    {% else %}
      <div class="py-4 text-center">
        <p class="cosmos-section__lead mx-auto mb-4" style="max-width:480px;">{{ home.events.subscribeLead }}</p>
        <a href="{{ home.events.subscribeButton.href }}" class="btn btn-lg cosmos-glow-btn cosmos-glow-btn--events" target="_blank" rel="noopener">
          <i class="bi {{ home.events.subscribeButton.icon }} me-2"></i>{{ home.events.subscribeButton.label }}
        </a>
      </div>
    {% endif %}
    <div><a href="{{ home.events.viewAllHref }}" class="cosmos-view-all cosmos-view-all--events d-md-none mt-4"{% if home.events.viewAllExternal %} target="_blank" rel="noopener"{% endif %}>{{ home.events.viewAllLabel }} <i class="bi bi-arrow-right"></i></a></div>
  </div>
</section>

<!-- ── CURATED RESOURCES ─────────────────────── -->
<section class="cosmos-section cosmos-section--raised cosmos-section--resources-home">
  <div class="container">
    <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
      <div>
        <h2 class="cosmos-section__title cosmos-section__title--resources mb-0"><i class="bi bi-book me-2"></i>{{ home.resources.title }}</h2>
      </div>
      <a href="{{ home.resources.viewAllHref }}" class="cosmos-view-all cosmos-view-all--resources d-none d-md-inline-flex">
        {{ home.resources.viewAllLabel }} <i class="bi bi-arrow-right"></i>
      </a>
    </div>
    <div class="row g-3 row-cols-2 row-cols-md-3 row-cols-lg-6">
      {% for area in focusAreas.areas %}
      <div class="col">
        <a href="{{ area.href }}" class="cosmos-focus-card{% if area.featured %} cosmos-focus-card--featured{% endif %}">
          <i class="bi {{ area.icon }} cosmos-focus-card__icon"></i>
          <div class="cosmos-focus-card__body">
            <h5 class="cosmos-focus-card__title">{{ area.title }}</h5>
            <p class="cosmos-focus-card__desc">{{ area.lead }}</p>
            <span class="cosmos-focus-card__link">{{ area.linkText }} <i class="bi bi-arrow-right"></i></span>
          </div>
        </a>
      </div>
      {% endfor %}
    </div>
    <div><a href="{{ home.resources.viewAllHref }}" class="cosmos-view-all cosmos-view-all--resources d-md-none mt-4">{{ home.resources.viewAllLabel }} <i class="bi bi-arrow-right"></i></a></div>
  </div>
</section>

<!-- ── JOIN THE CONVERSATION ─────────────────── -->
<section class="cosmos-section cosmos-section--raised">
  <div class="container">
    <div class="cosmos-cta-section cosmos-cta-section--chat">
      <div class="position-relative" style="z-index:1;">
        <h2 class="cosmos-cta-section__title cosmos-section__title--chat"><i class="bi {{ home.chat.button.icon }} me-2"></i>{{ home.chat.title }}</h2>
        <p class="cosmos-cta-section__lead">{{ home.chat.lead }}</p>
        <div class="cosmos-cta-section__actions">
          <a href="{{ home.chat.button.href }}" class="btn btn-lg cosmos-glow-btn cosmos-glow-btn--chat">
            <i class="bi {{ home.chat.button.icon }} me-2"></i>{{ home.chat.button.label }}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  var hint = document.getElementById('heroScrollHint');
  var spin = document.getElementById('heroScrollSpin');

  if (hint) {
    hint.addEventListener('click', function () {
      var next = document.querySelector('.cosmos-hero-pcb + *');
      if (next) next.scrollIntoView({ behavior: 'smooth' });
    });
  }

  function schedTwirl() {
    setTimeout(function () {
      if (!spin) return;
      spin.classList.add('do-spin');
      spin.addEventListener('animationend', function done() {
        spin.classList.remove('do-spin');
        spin.removeEventListener('animationend', done);
        schedTwirl();
      });
    }, 2800 + Math.random() * 5200);
  }
  schedTwirl();

  setTimeout(function () {
    if (hint && window.scrollY < 80) hint.style.opacity = '1';
  }, 1000);

  window.addEventListener('scroll', function () {
    if (hint) hint.style.opacity = Math.max(0, 1 - window.scrollY / 160).toString();
  }, { passive: true });
}());
</script>
