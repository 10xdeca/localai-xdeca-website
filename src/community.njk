---
layout: base.njk
title: Community Chat
description: Join the Local AI community chat on Discord, Telegram, WhatsApp, Signal, or Matrix. Pick whichever app you already use and your messages will reach everyone on all the others.
permalink: /community/
fullWidth: true
---

<!-- ── PAGE HERO ───────────────────────────── -->
<section class="cosmos-page-hero">
  <div class="container">
    <p class="cosmos-section__label">{{ community.hero.label }}</p>
    <h1 class="cosmos-section__title mb-2">{{ community.hero.title }}</h1>
    <p class="cosmos-section__lead" style="max-width:none;">{{ community.hero.lead }}</p>
  </div>
</section>

<!-- ── HOW IT WORKS + PLATFORMS ─────────────── -->
<section class="cosmos-section">
  <div class="container">
    <h2 class="cosmos-section__title mb-2" style="font-size:clamp(1rem,1.8vw,1.3rem);">{{ community.howItWorks.title }}</h2>
    <p class="cosmos-section__lead mb-4" style="max-width:none;">{{ community.howItWorks.lead }}</p>
    <div class="row g-0">
      {% for platform in community.platforms %}
      <div class="col-6 col-md-4 col-lg">
        <div class="cosmos-platform-card">
          <i class="bi {{ platform.icon }} cosmos-platform-card__icon"></i>
          <p class="cosmos-platform-card__name">{{ platform.name }}</p>
          <div class="cosmos-platform-card__qr{% if platform.comingSoon %} cosmos-platform-card__qr--placeholder{% endif %}">
            {% if platform.comingSoon %}
              <span>Coming soon</span>
            {% else %}
              <img src="{{ platform.qr }}" alt="{{ platform.name }} QR code" />
            {% endif %}
          </div>
          <a href="{{ platform.joinHref }}" class="btn btn-primary btn-sm w-100">Join</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── NEWSLETTER ─────────────────────────────── -->
<section class="cosmos-section">
  <div class="container text-center">
    <p class="cosmos-section__label">{{ community.newsletter.label }}</p>
    <h2 class="cosmos-section__title mb-2">{{ community.newsletter.title }}</h2>
    <p class="cosmos-section__lead mb-4 mx-auto">{{ community.newsletter.lead }}</p>
    <form class="cosmos-newsletter-form" action="{{ community.newsletter.actionHref }}" method="post">
      <div class="d-flex gap-2 justify-content-center">
        <input type="email" name="email" class="form-control" placeholder="{{ community.newsletter.placeholder }}" required style="max-width:320px;" />
        <button type="submit" class="btn btn-primary flex-shrink-0">{{ community.newsletter.buttonLabel }}</button>
      </div>
    </form>
  </div>
</section>
