---
layout: base.njk
title: About
description: What is local AI, and what does the Local AI do? Events, curated resources, and online discussions for anyone running AI on their own machine.
permalink: /about/
fullWidth: true
---

<!-- ── PAGE HERO ───────────────────────────── -->
<section class="cosmos-page-hero">
  <div class="container">
    <h1 class="cosmos-section__title mb-2">{{ about.hero.title }}</h1>
    <p class="cosmos-section__lead" style="max-width:none;">{{ about.hero.lead }}</p>
  </div>
</section>

<!-- ── WHAT IS LOCAL AI ──────────────────────── -->
<section class="cosmos-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-7">
        <h2 class="cosmos-section__title">{{ about.whatIsLocalAI.title }}</h2>
        <p class="cosmos-section__lead">{{ about.whatIsLocalAI.lead }}</p>
      </div>
    </div>
    <div class="cosmos-fact-list mt-4">
      {% for fact in about.facts %}
      <div class="cosmos-fact-item">
        <div class="cosmos-fact-item__icon"><i class="bi {{ fact.icon }}"></i></div>
        <div>
          <div class="cosmos-fact-item__title">{{ fact.title }}</div>
          <div class="cosmos-fact-item__body">{{ fact.body }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── WHAT WE DO ────────────────────────────── -->
<section class="cosmos-section cosmos-section--alt">
  <div class="container">
    <h2 class="cosmos-section__title mb-5">{{ about.whatWeDo.title }}</h2>
    <div class="row g-4">
      {% for card in about.whatWeDo.cards %}
      <div class="col-md-4">
        <div class="cosmos-audience-card cosmos-audience-card--{{ card.accent }}">
          <div class="cosmos-audience-card__icon">
            <i class="bi {{ card.icon }}"></i>
          </div>
          <h4 class="cosmos-audience-card__title cosmos-audience-card__title--{{ card.accent }}">{{ card.title }}</h4>
          <p class="cosmos-audience-card__body">{{ card.body }}</p>
          <a href="{{ card.link.href }}" class="cosmos-audience-card__link cosmos-audience-card__link--{{ card.accent }}"{% if card.link.external %} target="_blank" rel="noopener"{% endif %}>{{ card.link.label }} <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ── WHO IT'S FOR ──────────────────────────── -->
<section class="cosmos-section">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-4">
        <h2 class="cosmos-section__title">{{ about.whoItsFor.title | replace("\n", "<br>") | safe }}</h2>
        <p class="cosmos-section__lead">{{ about.whoItsFor.lead }}</p>
      </div>
      <div class="col-lg-8">
        <div class="row g-4">
          {% for card in about.whoItsFor.cards %}
          <div class="col-md-4">
            <div class="cosmos-audience-card">
              <div class="cosmos-audience-card__icon">
                <i class="bi {{ card.icon }}"></i>
              </div>
              <h4 class="cosmos-audience-card__title">{{ card.title }}</h4>
              <p class="cosmos-audience-card__body">{{ card.body }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
