<div class="footer-wrapper">
  <footer id="footer-main">

    <div class="footer-brand">
      <a href="/" class="cosmos-footer__brand-name">{{ site.title }}</a>
      <p class="cosmos-footer__tagline">
        A community for running AI offline and completely privately on your own computer.
        Part of <a href="https://xdeca.com" class="cosmos-footer__link" target="_blank" rel="noopener">xdeca.com</a>.
      </p>
    </div>

    <div class="footer-col">
      <h6 class="cosmos-footer__heading">Community</h6>
      <ul class="cosmos-footer__links">
        {% for item in navbar %}
        {% if item.footer %}
        <li><a href="{{ item.href }}" class="cosmos-footer__link">{{ item.title }}</a></li>
        {% endif %}
        {% endfor %}
        <li><a href="https://lu.ma/localai" class="cosmos-footer__link" target="_blank" rel="noopener">Events on lu.ma</a></li>
        <li><a href="https://xdeca.com" class="cosmos-footer__link" target="_blank" rel="noopener">xdeca.com</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h6 class="cosmos-footer__heading">Focus Areas</h6>
      <ul class="cosmos-footer__links">
        {% for item in navbar %}{% if item.children %}{% for child in item.children %}
        <li><a href="{{ child.href }}" class="cosmos-footer__link">{{ child.title }}</a></li>
        {% endfor %}{% endif %}{% endfor %}
      </ul>
    </div>

    <div class="footer-col">
      <h6 class="cosmos-footer__heading">Cities</h6>
      <ul class="cosmos-footer__links">
        <li><span class="cosmos-footer__link">Melbourne</span></li>
        <li><span class="cosmos-footer__link">Sydney</span></li>
        <li><span class="cosmos-footer__link">Adelaide</span></li>
        <li><span class="cosmos-footer__link">Regional &amp; Online</span></li>
      </ul>
    </div>

  </footer>

  <div class="footer-bottom">
    <span>© {{ global.currentYear }} Local AI Group · Part of <a href="https://xdeca.com" class="cosmos-footer__link" target="_blank" rel="noopener">xdeca.com</a></span>
    <span>Not affiliated with any AI company.</span>
  </div>
</div>
