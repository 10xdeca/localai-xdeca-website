{% if type == "preview" %}{% if excludeFeatured %}{% set posts = collections.previewPosts %}{% else %}{% set posts = collections.previewPostsAll %}{% endif %}{% else %}{% set posts = collections.posts %}{% endif %}
{% if posts and posts | length > 0 %}
<div class="row g-4">
{% for post in posts %}
<div class="col-md-6 col-lg-4">
<article class="cosmos-post-card">
{% if post.data.image %}<div class="cosmos-post-card__image"><img src="{{ post.data.image }}" alt="{{ post.data.title }}"></div>{% endif %}
<div class="cosmos-post-card__body">
{% if post.data.postDate %}<span class="cosmos-badge cosmos-badge--muted">{{ post.data.postDate | formatDate('MMM Do, YYYY') }}</span>{% endif %}
<h5 class="cosmos-post-card__title">{{ post.data.title }}</h5>
{% if post.data.description %}<p class="cosmos-post-card__desc">{{ post.data.description }}</p>{% endif %}
<a class="cosmos-post-card__link stretched-link" href="{{ post.data.permalink or post.url }}">Read more <i class="bi bi-arrow-right"></i></a>
</div>
</article>
</div>
{% endfor %}
</div>
{% if type == "preview" %}
<div class="text-center mt-4">
<a href="/posts/" class="cosmos-view-all" style="font-size:0.95rem;">View all {{ collections.posts | length }} posts <i class="bi bi-arrow-right"></i></a>
</div>
{% endif %}
{% else %}
<div class="cosmos-empty-state">
<i class="bi bi-file-text d-block mb-2" style="font-size:1.75rem;opacity:0.4;"></i>
No posts yet. Guides and resources coming soon.
</div>
{% endif %}
