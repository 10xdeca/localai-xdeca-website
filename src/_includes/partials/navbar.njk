<nav class="navbar sticky-top" id="navbar-main">
  <div class="container d-flex align-items-center justify-content-between gap-3">

    <!-- Brand -->
    <a class="navbar-brand" href="/">
      <span class="navbar-brand__name">{{ site.title }}</span>
    </a>

    <!-- Desktop nav links -->
    <div class="d-none d-md-flex align-items-center gap-1">
      {% for item in navbar %}
      {% if item.children %}
      <div class="dropdown">
        <a class="cosmos-nav-link dropdown-toggle" href="{{ item.href }}" role="button" data-bs-toggle="dropdown" aria-expanded="false">
          {{ item.title }}
        </a>
        <ul class="dropdown-menu cosmos-dropdown-menu">
          {% for child in item.children %}
          <li><a class="cosmos-dropdown-item{% if page.url == child.href %} active{% endif %}" href="{{ child.href }}">{{ child.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% else %}
      <a class="cosmos-nav-link{% if page.url == item.href %} active{% endif %}" href="{{ item.href }}">
        {{ item.title }}
      </a>
      {% endif %}
      {% endfor %}
    </div>

    <!-- Right controls -->
    <div class="d-flex align-items-center gap-2">
      <div class="theme-toggle" onclick="toggleTheme()" role="button" aria-label="Toggle colour theme" tabindex="0">
        <div class="toggle-track">
          <div class="toggle-thumb"></div>
        </div>
      </div>
      <button class="cosmos-nav-icon-btn" onclick="openSearch()" aria-label="Search">
        <i class="bi bi-search"></i>
      </button>
      <a href="https://lu.ma/localai" class="cosmos-nav-events d-none d-md-inline-flex" target="_blank" rel="noopener">Events</a>
      <button class="cosmos-nav-icon-btn d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#nav-mobile" aria-expanded="false" aria-label="Toggle navigation">
        <i class="bi bi-list fs-5"></i>
      </button>
    </div>

  </div>

  <!-- Mobile nav -->
  <div id="nav-mobile" class="collapse w-100" id="nav-mobile">
    <div class="container py-3 d-flex flex-column gap-1">
      {% for item in navbar %}
      <a class="cosmos-nav-link{% if page.url == item.href %} active{% endif %}" href="{{ item.href }}">
        {{ item.title }}
      </a>
      {% if item.children %}
      {% for child in item.children %}
      <a class="cosmos-nav-link cosmos-nav-link--sub{% if page.url == child.href %} active{% endif %}" href="{{ child.href }}">
        {{ child.title }}
      </a>
      {% endfor %}
      {% endif %}
      {% endfor %}
      <a href="https://lu.ma/localai" class="btn btn-primary btn-sm mt-2 align-self-start" target="_blank" rel="noopener">
        <i class="bi bi-calendar-event me-2"></i>Browse Events
      </a>
    </div>
  </div>
</nav>

<!-- Search Modal -->
<div class="modal fade" id="searchModal" tabindex="-1" aria-labelledby="searchModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0" style="background:var(--color-surface-raised);border-radius:0;border:1px solid rgba(var(--color-primary-rgb),0.2);">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title" id="searchModalLabel" style="font-family:'Orbitron',monospace;font-size:0.85rem;font-weight:700;letter-spacing:0.1em;color:var(--color-primary);">
          <i class="bi bi-search me-2"></i>{{ site.searchTitle | default("Search") }}
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2">
        <input
          type="text"
          class="form-control form-control-lg"
          id="searchInput"
          placeholder="{{ site.searchPlaceholder | default('Search content...') }}"
          oninput="performSearch()"
          style="border-color:rgba(var(--color-primary-rgb),0.25);background:var(--color-surface);color:var(--color-text);border-radius:0;font-family:'Share Tech Mono',monospace;font-size:0.9rem;"/>
        <div id="searchResults" class="mt-3" style="max-height:400px;overflow-y:auto;"></div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleTheme() {
    var html = document.documentElement;
    var next = html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-bs-theme', next);
    localStorage.setItem('theme', next);
  }

  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.querySelector('.theme-toggle');
    if (toggle) {
      toggle.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleTheme(); }
      });
    }
  });
</script>
