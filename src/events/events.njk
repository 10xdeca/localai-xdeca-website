<!-- ── PAGE HERO ───────────────────────────── -->
<section class="cosmos-page-hero cosmos-page-hero--events">
  <div class="container">
    <p class="cosmos-section__label" style="color:var(--color-events);">Meetups</p>
    <h1 class="cosmos-section__title cosmos-section__title--events mb-2">Events</h1>
    <p class="cosmos-section__lead" style="max-width:none;">Casual catchups, workshops, and demo nights. In person across Australian cities and online.</p>
  </div>
</section>

<!-- ── UPCOMING ───────────────────────────── -->
<section class="cosmos-section cosmos-section--dots-events">
  <div class="container">
    <h2 class="cosmos-section__title cosmos-section__title--events mb-4">Upcoming</h2>
    {% set type = "upcoming" %}
    {% include "partials/eventsList.njk" %}
  </div>
</section>

<!-- ── PAST ──────────────────────────────── -->
<section class="cosmos-section cosmos-section--raised">
  <div class="container">
    <h2 class="cosmos-section__title mb-4">Past Events</h2>
    {% set type = "past" %}
    {% include "partials/eventsList.njk" %}
  </div>
</section>

<!-- ── CTA ───────────────────────────────── -->
<section class="cosmos-section cosmos-section--alt">
  <div class="container text-center">
    <p class="cosmos-section__lead mx-auto mb-4">Get notified when new events are announced.</p>
    <a href="https://lu.ma/localai" class="btn btn-lg cosmos-glow-btn cosmos-glow-btn--events" target="_blank" rel="noopener">
      <i class="bi bi-calendar-plus me-2"></i>Follow on lu.ma
