{% if type == "upcoming" %}{% set events = collections.upcomingEvents %}{% elif type == "past" %}{% set events = collections.pastEvents %}{% elif type == "preview" %}{% if excludeFeatured %}{% set events = collections.previewEventsCombined %}{% else %}{% set events = collections.previewEventsCombinedAll %}{% endif %}{% elif type == "previewPast" %}{% if excludeFeatured %}{% set events = collections.previewPastEvents %}{% else %}{% set events = collections.previewPastEventsAll %}{% endif %}{% elif type == "previewUpcoming" %}{% if excludeFeatured %}{% set events = collections.previewUpcomingEvents %}{% else %}{% set events = collections.previewUpcomingEventsAll %}{% endif %}{% else %}{% set events = collections.events %}{% endif %}
{% if events and events | length > 0 %}
<div class="row g-4">
{% for event in events %}
<div class="col-md-6 col-lg-4">
<div class="cosmos-event-card">
{% if event.data.image %}<div class="cosmos-event-card__image"><img src="{{ event.data.image }}" alt="{{ event.data.title }}"></div>{% endif %}
<div class="cosmos-event-card__body">
<div class="d-flex gap-2 flex-wrap">{% if event.data.eventDate %}<span class="cosmos-badge cosmos-badge--primary"><i class="bi bi-calendar3"></i>{{ event.data.eventDate | formatDate('MMM Do, YYYY') }}</span>{% endif %}</div>
<h4 class="cosmos-event-card__title">{{ event.data.title }}</h4>
{% if event.data.description %}<p class="cosmos-event-card__desc">{{ event.data.description }}</p>{% endif %}
<div class="cosmos-event-card__meta-list">
{% if event.data.startTime or event.data.endTime %}<div class="cosmos-event-card__meta"><i class="bi bi-clock"></i><span>{%- if event.data.startTime %}{{ event.data.startTime }}{% endif -%}{%- if event.data.startTime and event.data.endTime %} to {% endif -%}{%- if event.data.endTime %}{{ event.data.endTime }}{% endif -%}</span></div>{% endif %}
{% if event.data.location %}<div class="cosmos-event-card__meta"><i class="bi bi-geo-alt"></i><span>{{ event.data.location }}</span></div>{% endif %}
</div>
<a href="{{ event.data.permalink or event.url }}" class="cosmos-event-card__btn stretched-link">Learn more <i class="bi bi-arrow-right"></i></a>
</div>
</div>
</div>
{% endfor %}
</div>
{% if type == "preview" or type == "previewPast" or type == "previewUpcoming" %}
<div class="text-center mt-4">
<a href="/events/" class="cosmos-view-all" style="font-size:0.95rem;">View all {{ collections.events | length }} events <i class="bi bi-arrow-right"></i></a>
</div>
{% endif %}
{% else %}
<div class="cosmos-empty-state">
<i class="bi bi-calendar3 d-block mb-2" style="font-size:1.75rem;opacity:0.4;"></i>
No events scheduled right now. Check back soon, or
<a href="https://lu.ma/localai" target="_blank" rel="noopener" style="color:var(--color-primary);">follow us on lu.ma</a>
to get notified.
</div>
{% endif %}
