---
layout: base.njk
title: Curated Resources
description: Maintained lists of the best tools, projects, models, and links across all local AI focus areas. Kept up to date as the space moves.
permalink: /resources/
fullWidth: true
---

<!-- ── PAGE HERO ───────────────────────────── -->
<section class="cosmos-page-hero">
  <div class="container">
    <p class="cosmos-section__label">{{ focusAreas.page.label }}</p>
    <h1 class="cosmos-section__title mb-2">{{ focusAreas.page.title }}</h1>
    <p class="cosmos-section__lead" style="max-width:none;">{{ focusAreas.page.lead }}</p>
  </div>
</section>

<!-- ── FOCUS AREA CARDS ─────────────────────── -->
<section class="cosmos-section">
  <div class="container">
    <div class="row g-4">
      {% for area in focusAreas.areas %}
      <div class="col-md-6 col-lg-4">
        <a href="{{ area.href }}" class="cosmos-resource-card">
          <div class="cosmos-resource-card__header">
            <i class="bi {{ area.icon }} cosmos-resource-card__icon"></i>
            <h2 class="cosmos-resource-card__title">{{ area.title }}</h2>
          </div>
          <p class="cosmos-resource-card__lead">{{ area.lead }}</p>
          <span class="cosmos-focus-card__link">{{ area.linkText }} <i class="bi bi-arrow-right"></i></span>
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
