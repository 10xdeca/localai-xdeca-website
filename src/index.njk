<script>
(function () {
  var hint = document.getElementById('heroScrollHint');
  var spin = document.getElementById('heroScrollSpin');

  // Click scrolls to the first section below the hero
  if (hint) {
    hint.addEventListener('click', function () {
      var next = document.querySelector('.cosmos-hero-pcb + *');
      if (next) next.scrollIntoView({ behavior: 'smooth' });
    });
  }

  // Occasional twirl (rotateY) every 3–8 s
  function schedTwirl() {
    setTimeout(function () {
      if (!spin) return;
      spin.classList.add('do-spin');
      spin.addEventListener('animationend', function done() {
        spin.classList.remove('do-spin');
        spin.removeEventListener('animationend', done);
        schedTwirl();
      });
    }, 2800 + Math.random() * 5200);
  }
  schedTwirl();

  // Fade in after 3 s (only if user hasn't already scrolled away)
  setTimeout(function () {
    if (hint && window.scrollY < 80) hint.style.opacity = '1';
  }, 3000);

  // Fade out as user scrolls away
  window.addEventListener('scroll', function () {
    if (hint) hint.style.opacity = Math.max(0, 1 - window.scrollY / 160).toString();
  }, { passive: true });
}());
</script>
